# Environment Variables — LLM Trading Project
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Anthropic Claude API ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_DEV=claude-haiku-4-5-20251001
CLAUDE_MODEL_LIVE=claude-sonnet-4-6

# ── Tradovate API ────────────────────────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_ACCOUNT_ID=
TRADOVATE_ENV=demo        # demo or live

# ── Telegram Bot ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── GitHub (for dashboard persistence) ───────────────
GITHUB_TOKEN=
GITHUB_REPO=yourusername/llm-trading-project
GITHUB_BRANCH=main

# ── Webhook Security ──────────────────────────────────
WEBHOOK_SECRET=your-secret-here

# ── Pipeline Settings ─────────────────────────────────
PIPELINE_MODE=advisory          # advisory | semi_auto | conditional_auto
MIN_CONFIDENCE_FOR_AUTO=high    # high | medium
MAX_DAILY_LOSS_USD=-200
MAX_OPEN_POSITIONS=1
TRADE_CUTOFF_TIME_ET=11:30
NEWS_BUFFER_MINUTES=30
MIN_VOLUME_RATIO=0.8

# ── Data Paths ────────────────────────────────────────
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
BACKTEST_RESULTS_PATH=data/backtest_results
